{
  "version": 2,
  "buildCommand": "",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/login.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/config.js",
      "destination": "/api/config"
    }
  ],
  "functions": {
    "api/catalog.js": {
      "maxDuration": 30,
      "includeFiles": "js/products.js"
    }
  }
}
