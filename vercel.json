{
  "version": 2,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/login.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
